# Public site URL (no trailing slash). Required in production so canonical URLs, Open Graph,
# JSON-LD, sitemap, and robots.txt point at your real domain (not localhost or *.vercel.app).
NEXT_PUBLIC_SITE_URL=https://www.rahul.studio

# Optional: Google Search Console HTML tag verification (content value only, not the full meta tag).
# After adding, deploy and complete verification in https://search.google.com/search-console
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
